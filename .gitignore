replay_pid*.txt

# --- Временные файлы ---
*.log
*.tmp
.cache/

# --- Docker bind mounts: в репозитории только заглушки .gitkeep ---
checkpoint/*
!checkpoint/.gitkeep
output/*
!output/.gitkeep
